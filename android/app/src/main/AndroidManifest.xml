<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- One read permission per Health Connect record type this app maps —
         see core domain types in HealthDataMapper.kt for the matching set. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />

    <!-- Required so the app can detect whether the standalone Health Connect
         app is installed on API 26-33 devices (it ships inside the OS on 34+). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:name=".HealthSyncApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.HealthSync"
        android:usesCleartextTraffic="true">
        <!-- usesCleartextTraffic is for local development against an
             emulator/LAN backend over plain http; remove once the backend
             is served over https in any non-local environment. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.HealthSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Android 14+ requires apps requesting Health Connect permissions
             to expose a privacy-policy entry point via this exact intent
             action. An alias (rather than a second filter on MainActivity)
             keeps this separate from the LAUNCHER intent. MainActivity
             checks the launching intent's action and opens straight to the
             in-app privacy policy screen when launched this way. -->
        <activity-alias
            android:name=".PrivacyPolicyAlias"
            android:exported="true"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
        
    </application>
</manifest>
